# Copy to fleetrts.env in this folder (or use ~/.fleetrts.env on the droplet).
# start_fleetrts.sh loads server/fleetrts.env first, then ~/.fleetrts.env.

# Public IPv4 or DNS name clients use to reach THIS droplet (not 127.0.0.1).
export FLEETRTS_RELAY_HOST="198.199.80.13"

# Optional (default 8766)
# export FLEETRTS_RELAY_PORT=8766

# Optional: where stub/relay logs go (default ~/fleetrts-logs)
# export FLEETRTS_LOGDIR="$HOME/fleetrts-logs"

# Optional: pid file path (default ~/.fleetrts-server.pids)
# export FLEETRTS_PIDFILE="$HOME/.fleetrts-server.pids"

# --- Optional: short commands (add to ~/.bashrc after first git pull) ---
# chmod +x ~/FleetRTS/server/start_fleetrts.sh ~/FleetRTS/server/stop_fleetrts.sh
# alias start_server='$HOME/FleetRTS/server/start_fleetrts.sh'
# alias stop_server='$HOME/FleetRTS/server/stop_fleetrts.sh'
